{
    "autoPaste": {
    	"enabled": true
    },
    "allowDuplicates": false,
    "maxHistory": 1000,
    "logFile": "~/.local/share/clipse/clipse.log",
    "historyFile": "~/.local/share/clipse/history.json",
    "tempDir": "~/.local/share/clipse/tmp",
    "themeFile": "custom_theme.json",
    "keyBindings": {
        "choose": "enter",
        "clearSelected": "S",
        "down": "down",
        "end": "end",
        "filter": "/",
        "home": "~",
        "more": "?",
        "nextPage": "right",
        "prevPage": "left",
        "preview": "tab",
        "quit": "q",
        "remove": "x",
        "selectDown": "ctrl+down",
        "selectSingle": "s",
        "selectUp": "ctrl+up",
        "togglePin": "p",
        "togglePinned": "tab",
        "up": "up",
        "yankFilter": "ctrl+s"
    },
    "imageDisplay": {
        "type": "basic",
        "scaleX": 9,
        "scaleY": 9,
        "heightCut": 2
    }
}
