{
  "/etc/*": {
    "filetype": "conf"
  },
  "/home/*/.config/*/*.conf": {
    "filetype": "conf"
  },
  "/home/*/.config/waybar/config": {
    "filetype": "json"
  },
  "autosu": true,
  "colorscheme": "dracula",
  "diffgutter": true,
  "matchbracestyle": "highlight",
  "mkparents": true,
  "savecursor": true,
  "keymenu": false,
  "statusformatl": "  micro | $(filename) $(modified)",
  "statusformatr": "($(line),$(col)) $(lines) | $(opt:filetype) "
}
