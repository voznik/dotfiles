{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "manual",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "git *": "ask",
      "ls *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "fd *": "allow",
      "wc *": "allow",
      "rm *": "deny"
    },
    "list": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "external_directory": {
      "~/.ai/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.rulesync/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "context7-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "basic-memory": {
      "type": "local",
      "command": [
        "basic-memory",
        "mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "mise": {
      "type": "local",
      "command": [
        "mise",
        "mcp"
      ],
      "enabled": true
    },
    "rulesync-mcp": {
      "type": "local",
      "command": [
        "rulesync",
        "mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "instructions": [
    "~/.rulesync/rules/overview.md"
  ],
  "disabled_providers": [
    "openai",
    "azure"
  ],
  "formatter": false,
  "experimental": {
    "batch_tool": true
  },
  "tools": {
    "basic-memory_build_context": true,
    "basic-memory_read_content": true,
    "basic-memory_read_note": true,
    "basic-memory_search_notes": true,
    "basic-memory_search": true,
    "basic-memory_write_note": true,
    "basic-memory_edit_note": true,
    "basic-memory_recent_activity": true
  }
}
