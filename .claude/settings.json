{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": "disabled",
  "env": {
    "CLAUDE_CODE_SHELL": "bash",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$SHELL -c 'mise format'",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$SHELL -c 'uv run $HOME/.rulesync/hooks/damage-control/bash-tool-damage-control.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$SHELL -c 'uv run $HOME/.rulesync/hooks/damage-control/edit-tool-damage-control.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$SHELL -c 'uv run $HOME/.rulesync/hooks/damage-control/write-tool-damage-control.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/prevent-main-edit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-code-docs/claude-docs-helper.sh hook-check"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/setup.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/github-mcp-toggle.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$SHELL -c 'bd prime'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/skill-eval/skill-eval.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/.claude)",
      "Read(~/.rulesync)",
      "Bash(jq:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(~/.claude-code-docs/claude-docs-helper.sh *)"
    ],
    "deny": [
      "Read(~/.ssh/id*)",
      "Read(~/.env*)",
      "Read(**/credentials)",
      "Read(**/*.env*)",
      "Bash(apt*)",
      "Bash(yum*)",
      "Bash(dnf*)",
      "Bash(pacman*)",
      "Bash(brew*)",
      "Bash(sudo*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:schemastore.org)",
      "WebFetch(domain:www.schemastore.org)",
      "WebFetch(domain:json.schemastore.org)",
      "Task(claude-code-guide)"
    ]
  },
  "statusLine": {
    "command": "\"$HOME\"/.claude/scripts/context-bar.sh",
    "type": "command"
  }
}
