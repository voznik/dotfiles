{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/refs/heads/main/schemas/settings.schema.json",
  "experimental": {
    "enableAgents": true,
    "plan": true
  },
  "advanced": {
    "autoConfigureMemory": false,
    "excludedEnvVars": [
      "DEBUG",
      "DEBUG_MODE",
      "__SHELL"
    ]
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "replace|replace|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); file_path=$(printf \"%s\" \"$input\" | jq -r .tool_input.file_path); if [ -n \"$file_path\" ] && [ \"$file_path\" != \"null\" ]; then bash -c \"mise format $file_path\"; fi",
            "timeout": 30000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$SHELL -c 'bd sync'",
            "description": "Sync bd before context compaction",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | bash -c 'uv run $HOME/.rulesync/hooks/damage-control/bash-tool-damage-control.py'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "replace",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | bash -c 'uv run $HOME/.rulesync/hooks/damage-control/edit-tool-damage-control.py'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "replace|replace|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | $HOME/.rulesync/hooks/prevent-main-edit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "read_file",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | $HOME/.claude-code-docs/claude-docs-helper.sh hook-check",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | bash -c 'uv run $HOME/.rulesync/hooks/damage-control/write-tool-damage-control.py'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/setup.sh",
            "timeout": 10000,
            "description": "Run rulesync setup on session start"
          },
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/github-mcp-toggle.sh",
            "timeout": 5000,
            "description": "Toggle GitHub MCP server on session start"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.rulesync/hooks/skill-eval/skill-eval.sh",
            "timeout": 5000,
            "description": "Evaluate and activate relevant skills before prompt submission"
          }
        ]
      }
    ],
    "enabled": [
      "SessionStart",
      "PreCompress",
      "BeforeAgent",
      "BeforeModel",
      "BeforeTool",
      "AfterTool"
    ],
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); printf \"%s\" \"$input\" | $HOME/.rulesync/hooks/skill-eval/skill-eval.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "hooksConfig": {
    "enabled": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableYoloMode": false
  },
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "enableAutoUpdate": false,
    "preferredEditor": "zeditor",
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "ui": {
    "showStatusInTitle": true,
    "footer": {
      "hideContextPercentage": false
    },
    "dynamicWindowTitle": false,
    "hideTips": true,
    "showMemoryUsage": true,
    "showLineNumbers": true,
    "showModelInfoInChat": true,
    "accessibility": {
      "enableLoadingPhrases": false
    },
    "hideBanner": true,
    "useAlternateBuffer": false,
    "theme": "Dracula",
    "loadingPhrases": "off"
  },
  "telemetry": {
    "enabled": false
  },
  "tools": {
    "shell": {
      "showColor": true,
      "enableInteractiveShell": false
    },
    "truncateToolOutputThreshold": 100000
  },
  "mcp": {
    "allowed": [
      "context7",
      "basic-memory",
      "mise"
    ]
  },
  "context": {
    "discoveryMaxDirs": 10,
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "model": {
    "compressionThreshold": 0.2
  },
  "modelConfigs": {
    "customAliases": {
      "gemini-pro-strict": {
        "extends": "gemini-2.5-pro",
        "modelConfig": {
          "generateContentConfig": {
            "temperature": 0.1,
            "topP": 0.8
          }
        }
      },
      "gemini-flash-strict": {
        "extends": "gemini-3-flash-preview",
        "modelConfig": {
          "generateContentConfig": {
            "temperature": 0.1,
            "topP": 0.8
          }
        }
      }
    }
  },
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "context7-mcp",
      "args": [],
      "env": {}
    },
    "basic-memory": {
      "type": "stdio",
      "command": "basic-memory",
      "args": [
        "mcp"
      ],
      "env": {},
      "includeTools": [
        "build_context",
        "read_content",
        "read_note",
        "search_notes",
        "search",
        "write_note",
        "edit_note",
        "recent_activity"
      ]
    },
    "mise": {
      "command": "mise",
      "args": [
        "mcp"
      ],
      "type": "stdio"
    },
    "rulesync-mcp": {
      "type": "stdio",
      "command": "rulesync",
      "args": [
        "mcp"
      ],
      "env": {}
    }
  }
}
